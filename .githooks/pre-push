#!/bin/sh
# pre-push hook: コミット漏れのソースファイルがあればpushを止める

CHANGED=$(git diff --name-only apps/ packages/ 2>/dev/null)

if [ -n "$CHANGED" ]; then
  echo ""
  echo "❌ Push blocked: コミットされていない変更があります"
  echo ""
  echo "$CHANGED" | sed 's/^/  - /'
  echo ""
  echo "以下を実行してから再度pushしてください:"
  echo "  git add <ファイル名>"
  echo "  git commit -m 'fix: ...'"
  echo ""
  exit 1
fi

exit 0
